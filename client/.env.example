# Frontend - Variables de Entorno
# Copia este archivo como .env y configura tus valores

# URL de la API del backend
# Para desarrollo: http://localhost:3001/api
# Para producción (Render): https://tu-app.onrender.com/api
VITE_API_URL=http://localhost:3001/api

# ============================================
# NOTA PARA RENDER:
# En el dashboard de Render (del servicio del backend),
# NO necesitas configurar esta variable aquí.
# El frontend se sirve desde el mismo servidor del backend,
# así que las llamadas a /api funcionarán automáticamente.
# Si usas un dominio personalizado, actualiza VITE_API_URL
# ============================================