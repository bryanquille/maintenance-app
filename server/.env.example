# Backend - Variables de Entorno
# Copia este archivo como .env y configura tus valores

# MongoDB Atlas Connection String
# Ejemplo: mongodb+srv://<user>:<password>@cluster.mongodb.net/maintanance-app
MONGODB_URI=mongodb+srv://your_connection_string_here

# JWT Secret - Genera una clave segura para producción
# Puedes usar: openssl rand -hex 32 para generar una clave segura
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production

# Puerto del servidor
# Render asigna automáticamente el puerto mediante la variable PORT
PORT=3001

# Origen de CORS (URL del frontend en producción)
# Para desarrollo: http://localhost:5173
# Para producción (Render): https://tu-app.onrender.com
CORS_ORIGIN=http://localhost:5173

# ============================================
# NOTA PARA RENDER:
# En el dashboard de Render, configura estas variables:
# - MONGODB_URI = tu URI de MongoDB Atlas
# - JWT_SECRET = clave segura (genérala con openssl rand -hex 32)
# - CORS_ORIGIN = https://tu-app.onrender.com (tu URL de Render)
# - PORT = no necesitas configurarla, Render lo hace automáticamente
# ============================================